{
  "name": "cygnet",
  "version": "0.3.1",
  "description": "A modern framework for building Signal bots",
  "license": "MIT",
  "keywords": [
    "signal",
    "signal-cli",
    "signal-cli-rest-api",
    "bot",
    "bots",
    "bot-framework",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sudodaksh/cygnet.git"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "typecheck": "bun tsc --noEmit",
    "build:js": "bun build ./index.ts --outdir ./dist --target node --format esm --sourcemap=linked",
    "build:types": "bun tsc -p tsconfig.build.json && bun run ./scripts/fix-dts-imports.mjs",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/bun": "latest",
    "rimraf": "^6.1.3",
    "typescript": "^5"
  }
}